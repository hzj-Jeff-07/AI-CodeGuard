{
  "name": "ai-codeguard",
  "version": "0.4.0",
  "description": "AI-powered code security scanner combining static analysis with LLM intelligence",
  "type": "module",
  "bin": {
    "ai-codeguard": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hzj-Jeff-07/AI-CodeGuard.git"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build && npm run test:run",
    "scan:self": "node dist/index.js scan ./src",
    "precision": "vitest run tests/precision",
    "triage": "vitest run tests/triage"
  },
  "keywords": [
    "security",
    "scanner",
    "ast",
    "llm",
    "owasp",
    "sarif",
    "static-analysis"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "cosmiconfig": "^9.0.0",
    "fast-glob": "^3.3.3",
    "openai": "^4.85.0",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-php": "^0.24.2",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.26.8",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "eslint": "^9.19.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^3.0.5"
  }
}
